// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Account {
  id         Int      @id @default(autoincrement())
  name       String
  balance    Decimal  @default(0) @db.Decimal(18,2)
  created_at DateTime @default(now())
  active     Boolean  @default(true)

  Incomes  Income[]
  recurrentIncomes RecurrentIncome[]
  expenses Expense[]
  recurrentExpenses RecurrentExpense[]
  fromTransactions Transaction[] @relation("FromAccount")
  toTransactions   Transaction[] @relation("ToAccount")
  recurrentFromTransactions RecurrentTransaction[] @relation("RecurrentFromAccount")
  recurrentToTransactions   RecurrentTransaction[] @relation("RecurrentToAccount")
  monthSnapshots   MonthSnapshot[]
}

model Income {
  id            Int      @id @default(autoincrement())
  account_id    Int
  job_run_id    Int?
  amount        Decimal  @db.Decimal(18,2)
  description   String?
  created_at    DateTime @default(now())
  processed_at  DateTime?
  processing_error String?
  
  month_id      Int
  month         Month @relation(fields: [month_id], references: [id])
  job_run       JobRun? @relation(fields: [job_run_id], references: [id])

  account       Account @relation(fields: [account_id], references: [id])
  status        IncomeStatus @default(COMPLETED)
  recurrentIncomeRuns RecurrentIncomeRun[]

  @@index([job_run_id])
  @@index([month_id, status])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  from_account_id Int
  to_account_id   Int
  job_run_id      Int?
  amount          Decimal  @db.Decimal(18,2)
  description     String?
  created_at      DateTime @default(now())

  processed_at    DateTime?
  processing_error String?

  from_account Account @relation("FromAccount", fields: [from_account_id], references: [id])
  to_account   Account @relation("ToAccount", fields: [to_account_id], references: [id])
  job_run      JobRun? @relation(fields: [job_run_id], references: [id])
  recurrentTransactionRuns RecurrentTransactionRun[]

  month_id        Int
  month          Month @relation(fields: [month_id], references: [id])

  status TransactionStatus @default(PENDING)

  @@index([job_run_id])
  @@index([month_id, status])
}

model Expense {
  id               Int      @id @default(autoincrement())
  account_id       Int
  job_run_id       Int?
  amount           Decimal  @db.Decimal(18,2)
  description      String?
  kind             ExpenseKind @default(FIXED)
  created_at       DateTime @default(now())
  processed_at     DateTime?
  processing_error String?

  month_id Int
  month    Month @relation(fields: [month_id], references: [id])
  job_run  JobRun? @relation(fields: [job_run_id], references: [id])

  account Account @relation(fields: [account_id], references: [id])
  status  ExpenseStatus @default(PENDING)
  recurrentExpenseRuns RecurrentExpenseRun[]

  @@index([job_run_id])
  @@index([month_id, status])
}

model RecurrentIncome {
  id                    Int      @id @default(autoincrement())
  account_id            Int
  amount                Decimal  @db.Decimal(18,2)
  description           String?
  start_month           DateTime?
  end_month             DateTime?
  next_run_year         Int?
  next_run_month        Int?
  last_applied_month_id Int?
  status                RecurrentIncomeStatus @default(ACTIVE)
  created_at            DateTime @default(now())

  account            Account @relation(fields: [account_id], references: [id])
  last_applied_month Month?  @relation("RecurrentIncomeLastAppliedMonth", fields: [last_applied_month_id], references: [id])
  runs               RecurrentIncomeRun[]

  @@index([account_id, status])
  @@index([next_run_year, next_run_month])
  @@index([last_applied_month_id])
}

model RecurrentIncomeRun {
  id                  Int      @id @default(autoincrement())
  recurrent_income_id Int
  month_id            Int
  income_id           Int?
  job_run_id          Int?
  status              RecurrentIncomeRunStatus
  processing_error    String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  recurrent_income RecurrentIncome @relation(fields: [recurrent_income_id], references: [id])
  month            Month           @relation(fields: [month_id], references: [id])
  income           Income?         @relation(fields: [income_id], references: [id])
  job_run          JobRun?         @relation(fields: [job_run_id], references: [id])

  @@unique([recurrent_income_id, month_id], name: "recurrent_income_month")
  @@index([month_id])
  @@index([job_run_id])
  @@index([status])
}

model RecurrentExpense {
  id                    Int      @id @default(autoincrement())
  account_id            Int
  amount                Decimal  @db.Decimal(18,2)
  description           String?
  kind                  ExpenseKind @default(FIXED)
  start_month           DateTime?
  end_month             DateTime?
  next_run_year         Int?
  next_run_month        Int?
  last_applied_month_id Int?
  status                RecurrentExpenseStatus @default(ACTIVE)
  created_at            DateTime @default(now())

  account            Account @relation(fields: [account_id], references: [id])
  last_applied_month Month?  @relation("RecurrentExpenseLastAppliedMonth", fields: [last_applied_month_id], references: [id])
  runs               RecurrentExpenseRun[]

  @@index([account_id, status])
  @@index([next_run_year, next_run_month])
  @@index([last_applied_month_id])
}

model RecurrentExpenseRun {
  id                   Int      @id @default(autoincrement())
  recurrent_expense_id Int
  month_id             Int
  expense_id           Int?
  job_run_id           Int?
  status               RecurrentExpenseRunStatus
  processing_error     String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  recurrent_expense RecurrentExpense @relation(fields: [recurrent_expense_id], references: [id])
  month            Month            @relation(fields: [month_id], references: [id])
  expense          Expense?         @relation(fields: [expense_id], references: [id])
  job_run          JobRun?          @relation(fields: [job_run_id], references: [id])

  @@unique([recurrent_expense_id, month_id], name: "recurrent_expense_month")
  @@index([month_id])
  @@index([job_run_id])
  @@index([status])
}

model RecurrentTransaction {
  id                    Int      @id @default(autoincrement())
  from_account_id       Int
  to_account_id         Int
  amount                Decimal  @db.Decimal(18,2)
  description           String?
  start_month           DateTime?
  end_month             DateTime?
  next_run_year         Int?
  next_run_month        Int?
  last_applied_month_id Int?
  status                RecurrentTransactionStatus @default(ACTIVE)
  created_at            DateTime @default(now())

  from_account       Account @relation("RecurrentFromAccount", fields: [from_account_id], references: [id])
  to_account         Account @relation("RecurrentToAccount", fields: [to_account_id], references: [id])
  last_applied_month Month?  @relation("RecurrentTransactionLastAppliedMonth", fields: [last_applied_month_id], references: [id])
  runs               RecurrentTransactionRun[]

  @@index([from_account_id, status])
  @@index([to_account_id, status])
  @@index([next_run_year, next_run_month])
  @@index([last_applied_month_id])
}

model RecurrentTransactionRun {
  id                       Int      @id @default(autoincrement())
  recurrent_transaction_id Int
  month_id                 Int
  transaction_id           Int?
  job_run_id               Int?
  status                   RecurrentTransactionRunStatus
  processing_error         String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  recurrent_transaction RecurrentTransaction @relation(fields: [recurrent_transaction_id], references: [id])
  month                Month                @relation(fields: [month_id], references: [id])
  transaction          Transaction?         @relation(fields: [transaction_id], references: [id])
  job_run              JobRun?              @relation(fields: [job_run_id], references: [id])

  @@unique([recurrent_transaction_id, month_id], name: "recurrent_transaction_month")
  @@index([month_id])
  @@index([job_run_id])
  @@index([status])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum IncomeStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ExpenseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum ExpenseKind {
  FIXED
  VARIABLE
}

enum RecurrentIncomeRunStatus {
  APPLIED
  FAILED
}

enum RecurrentExpenseRunStatus {
  APPLIED
  FAILED
}

enum RecurrentIncomeStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum RecurrentExpenseStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum RecurrentTransactionRunStatus {
  APPLIED
  FAILED
}

enum RecurrentTransactionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum JobRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model Month {
  id        Int      @id @default(autoincrement())
  year      Int
  month      Int
  created_at DateTime @default(now())

  @@unique([year, month], name: "year_month")
  
  // 0..* for a month
  incomes Income[]
  lastAppliedRecurrentIncomes RecurrentIncome[] @relation("RecurrentIncomeLastAppliedMonth")
  recurrentIncomeRuns RecurrentIncomeRun[]
  expenses Expense[]
  lastAppliedRecurrentExpenses RecurrentExpense[] @relation("RecurrentExpenseLastAppliedMonth")
  recurrentExpenseRuns RecurrentExpenseRun[]
  transactions Transaction[]
  lastAppliedRecurrentTransactions RecurrentTransaction[] @relation("RecurrentTransactionLastAppliedMonth")
  recurrentTransactionRuns RecurrentTransactionRun[]
  monthSnapshots MonthSnapshot[]
}

model MonthSnapshot {
  id                     Int      @id @default(autoincrement())
  month_id               Int
  account_id             Int
  total_incomes          Decimal  @default(0) @db.Decimal(18,2)
  total_expenses         Decimal  @default(0) @db.Decimal(18,2)
  total_transactions_in  Decimal  @default(0) @db.Decimal(18,2)
  total_transactions_out Decimal  @default(0) @db.Decimal(18,2)
  is_final               Boolean  @default(false)
  closed_at              DateTime?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  month   Month   @relation(fields: [month_id], references: [id])
  account Account @relation(fields: [account_id], references: [id])

  @@unique([month_id, account_id], name: "month_account")
  @@index([account_id])
}

model JobRun {
  id             Int          @id @default(autoincrement())
  job_name       String
  madrid_date    String       @db.VarChar(10)
  status         JobRunStatus @default(RUNNING)
  started_at     DateTime     @default(now())
  finished_at    DateTime?
  processed_count Int         @default(0)
  failed_count   Int          @default(0)
  skipped_count  Int          @default(0)
  error_message  String?
  incomes        Income[]
  recurrentIncomeRuns RecurrentIncomeRun[]
  expenses       Expense[]
  recurrentExpenseRuns RecurrentExpenseRun[]
  transactions   Transaction[]
  recurrentTransactionRuns RecurrentTransactionRun[]

  @@unique([job_name, madrid_date], name: "job_name_madrid_date")
}


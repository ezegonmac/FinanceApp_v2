// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Account {
  id         Int      @id @default(autoincrement())
  name       String
  balance    Decimal  @default(0) @db.Decimal(18,2)
  created_at DateTime @default(now())
  active     Boolean  @default(true)

  Incomes  Income[]
  fromTransactions Transaction[] @relation("FromAccount")
  toTransactions   Transaction[] @relation("ToAccount")
}

model Income {
  id            Int      @id @default(autoincrement())
  account_id    Int
  amount        Decimal  @db.Decimal(18,2)
  description   String?
  created_at      DateTime @default(now())
  
  month_id        Int
  month          Month @relation(fields: [month_id], references: [id])

  account Account @relation(fields: [account_id], references: [id])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  from_account_id Int
  to_account_id   Int
  amount          Decimal  @db.Decimal(18,2)
  description     String?
  created_at      DateTime @default(now())

  from_account Account @relation("FromAccount", fields: [from_account_id], references: [id])
  to_account   Account @relation("ToAccount", fields: [to_account_id], references: [id])

  month_id        Int
  month          Month @relation(fields: [month_id], references: [id])

  status TransactionStatus @default(PENDING)

  @@index([month_id, status])
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Month {
  id        Int      @id @default(autoincrement())
  year      Int
  month      Int
  created_at DateTime @default(now())

  @@unique([year, month], name: "year_month")
  
  // 0..* for a month
  incomes Income[]
  transactions Transaction[]
}

